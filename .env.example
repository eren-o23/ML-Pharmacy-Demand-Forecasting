# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost:5432/pharmacydb

# ML Pipeline Configuration
# Path relative to ml/ directory when running the pipeline
RAW_DATA_CSV_PATH=./salesdaily.csv

# Optional: Model Configuration
FORECAST_HORIZON_DAYS=30

# Directory where trained model files are saved/loaded (optional)
MODEL_SAVE_DIR=./saved_models

# ISO country code for public holiday detection (default: SI for Slovenia)
HOLIDAYS_COUNTRY=SI
